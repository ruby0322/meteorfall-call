{
  "name": "meteorfall-call",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -c \"blue.bold,magenta.bold\" -n \"FRONTEND,BACKEND\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "dev:backend": "bash -lc 'cd apps/backend && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000'",
    "test": "bash -lc 'cd apps/backend && python -m pytest tests/ -v'"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
