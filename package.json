{
  "name": "meteorfall-call",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -c \"blue.bold,magenta.bold\" -n \"FRONTEND,BACKEND\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "dev:backend": "bash scripts/dev-backend.sh",
    "test": "bash scripts/run-tests.sh",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
