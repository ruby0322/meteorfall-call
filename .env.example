# Most topics in this screen don't need an API key.
# Anything key-shaped detected in git history is an auto-fail (gitleaks).
#
# Copy to .env and adjust if needed:
#   cp .env.example .env

# Postgres (used by docker compose; not exposed to host by default)
POSTGRES_PASSWORD=marketmage-local-dev-change-me
# Optional host bind if you need psql from the machine (pick a free port):
# POSTGRES_PORT_BIND=127.0.0.1:5433

# Service ports (host bindings)
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Local dev without Docker (optional overrides)
DATABASE_URL=sqlite+pysqlite:///./marketmage.db
BACKEND_INTERNAL_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=
